// E-book Generator - Prisma Schema
// SQLite (local) + Supabase (cloud sync via REST API)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Book {
  id              String    @id @default(cuid())
  userId          String?   // Supabase auth user ID (null for anonymous/local)
  prompt          String    // The user's original prompt / topic description
  audience        String    @default("General readers")
  tone            String    @default("Informative and engaging")
  lengthHint      String    @default("Medium (8-12 chapters)")
  status          String    @default("PLANNING") // PLANNING | WRITING | EXPORTING | DONE | FAILED
  title           String?
  subtitle        String?
  tocJson         String?   // JSON string: [{ chapterTitle, subTopics[] }]
  phasesJson      String?   // JSON string: { planning, writing, exporting }
  errorMessage    String?
  epubPath        String?
  pdfPath         String?
  tokenUsageJson  String?   // JSON: { totalPromptTokens, totalCompletionTokens, totalTokens, estimatedCost, calls[] }
  metadataJson    String?   // JSON: { keywords[], abstract, isbnPlaceholder, copyrightYear, copyrightPage, language, subject }
  language        String    @default("en") // Language code for the book content
  mobiPath        String?   // Path to generated MOBI file
  pdfTemplate     String    @default("professional") // professional | academic | creative | minimalist
  coverImagePath  String?   // Path to generated cover image
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt
  completedAt     DateTime?

  chapters        Chapter[]

  @@map("books")
}

model Chapter {
  id            String   @id @default(cuid())
  bookId        String
  chapterNumber Int
  title         String
  outline       String?  // Sub-topics / bullet outline for this chapter
  markdown      String?  // Generated Markdown content
  status        String   @default("PENDING") // PENDING | GENERATING | EDITING | DONE | FAILED
  generatedAt   DateTime?
  editedAt      DateTime?

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@map("chapters")
}

model AgentSession {
  id              String   @id @default(cuid())
  userId          String?  // Supabase auth user ID
  niche           String   // Selected niche (e.g., "Health & Wellness")
  subNiche        String   // Selected sub-niche (e.g., "Keto za žene 40+")
  customNiche     String?  // Custom niche input if user typed their own
  bookCount       Int      @default(1) // How many books to generate
  currentStep     Int      @default(1) // 1-5 which agent step is active
  status          String   @default("active") // active | completed | failed | paused
  nicheDataJson   String?  // JSON: Agent 1 results (profitability, demand, competition scores)
  competitionDataJson String? // JSON: Agent 2 part 1 (competition analysis)
  evaluationDataJson  String? // JSON: Agent 3 (quality assessment scores)
  seoDataJson         String? // JSON: Agent 4 (SEO title, description, tags, pricing)
  coverDataJson       String? // JSON: Agent 5 (cover prompt + image path)
  generatedBookIds    String? // JSON: array of book IDs generated by Agent 2
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("agent_sessions")
}
